# --- Vite client-side variables (prefix VITE_, exposed to the browser) ---

# Build-time toggle for the AI fact rewriter. When "true", the client posts to
# /api/kid-fact each round to get a kid-friendly rewrite of the Wikipedia
# extract. When unset/false (Tier 1, no Anthropic key), the client skips the
# call entirely so we don't waste a network round-trip on a guaranteed 503.
# Pair this with ANTHROPIC_API_KEY below for the rewriter to actually work.
# VITE_KID_FACT_ENABLED=true

# --- Cloudflare Pages Functions secrets (server-side, NOT exposed) ---
# Set these in the Cloudflare Pages dashboard for production + preview.
# For local dev with `wrangler pages dev`, copy this file to .dev.vars
# (gitignored) and fill in.

UNSPLASH_ACCESS_KEY=your-unsplash-access-key
PEXELS_API_KEY=your-pexels-api-key

# Anthropic API key for the kid-friendly fact rewriter (functions/api/kid-fact).
# Without this, the app falls back to the Wikipedia first-sentence (still works,
# just dense Wikipedia tone instead of "rewritten for a 7-year-old").
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: override which Claude model rewrites facts. Defaults to Opus 4.7
# for best tone. Cost-sensitive deploys can swap to claude-haiku-4-5 — same
# prompt, ~3-5x cheaper, slightly less polished but still kid-appropriate.
# ANTHROPIC_KID_FACT_MODEL=claude-haiku-4-5
